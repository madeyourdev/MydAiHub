# Supabase — Transaction Pooler (port 6543) — used by PrismaClient at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — Session Pooler (port 5432) — used by Prisma CLI for migrations (IPv4 compatible)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="replace-with-your-secret"
JWT_EXPIRES_IN="1d"

# Cookie
COOKIE_EXPIRES_DAYS="1"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID="replace-with-your-google-client-id"

# Supabase SSL Certificate — required in production, optional in development
# ใช้สำหรับ verify SSL certificate ตอนต่อ DB เพื่อป้องกัน MITM attack
# วิธีได้ค่านี้:
#   1. Supabase Dashboard → Project Settings → Database → Download Certificate
#   2. รัน: base64 -i prod-ca-2021.crt | tr -d '\n'
#   3. วาง output ที่ได้ตรงนี้
# หมายเหตุ: ถ้าไม่ตั้งใน production app จะไม่ขึ้น
SUPABASE_SSL_CERT=""

# Groq — https://console.groq.com/ (ฟรี ไม่ต้องใส่บัตร)
# ใช้สำหรับเรียก AI ในหน้า Chat
# เมื่อต้องการเปลี่ยนไปใช้ OpenRouter ให้เปลี่ยนเป็น OPENROUTER_API_KEY และแก้ baseURL ใน src/chat/chat.service.ts
GROQ_API_KEY="gsk_replace-with-your-key"

# App
FRONTEND_URL="http://localhost:5173"
PORT=3000
