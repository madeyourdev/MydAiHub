# Supabase — Transaction Pooler (port 6543) — used by PrismaClient at runtime
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase — Session Pooler (port 5432) — used by Prisma CLI for migrations (IPv4 compatible)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="replace-with-your-secret"
JWT_EXPIRES_IN="1d"

# Cookie
COOKIE_EXPIRES_DAYS="1"

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID="replace-with-your-google-client-id"

# App
FRONTEND_URL="http://localhost:5173"
PORT=3000
